{
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-env --allow-run build.ts",
    "check": "deno check src/**/*.ts",
    "test": "deno test --allow-read --allow-write"
  },
  "imports": {
    "esbuild": "npm:esbuild@0.24.2",
    "fast-check": "npm:fast-check@3.23.2"
  },
  "fmt": {
    "lineWidth": 100
  }
}
